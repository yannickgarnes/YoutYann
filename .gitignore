# ═══════════════════════════════════════
# YoutYann .gitignore
# ═══════════════════════════════════════

# Secrets — NEVER commit these
token.json
client_secret.json
*.cookies.txt
cookies.txt

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
venv/
.env

# Temp files
temp/
*.mp4
*.mp3
*.srt
*.ass
*.jpg
*.png
*.wav
*.txt.tmp

# FFmpeg binaries
ffmpeg.exe
ffprobe.exe
ffmpeg.zip
ffmpeg_unzipped/

# Logs
*.log
youtyann.log

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo
